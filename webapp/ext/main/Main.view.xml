<mvc:View xmlns:core="sap.ui.core" xmlns:mvc="sap.ui.core.mvc" xmlns="sap.m" xmlns:macros="sap.fe.macros" xmlns:layout="sap.ui.layout" xmlns:macrosTable="sap.fe.macros.table" xmlns:f="sap.f" xmlns:mdc="sap.ui.mdc"
	xmlns:mdct="sap.ui.mdc.table" xmlns:html="http://www.w3.org/1999/xhtml" controllerName="zwm311countreq.ext.main.Main">
    <f:DynamicPage id="FilterBarVMWithTable" class="sapUiResponsiveContentPadding" showFooter="{= ${message>/}.length > 0 }">
        <f:title>
            <f:DynamicPageTitle id="_IDGenDynamicPageTitle1">
                <f:heading>
                    <Title id="_IDGenTitle" text="{i18n>MainTitle}"/>
                </f:heading>
            </f:DynamicPageTitle>
        </f:title>
        <f:header>
            <f:DynamicPageHeader id="_IDGenDynamicPageHeader1" pinnable="true">
                <VBox id="idSelectionContainer">
                    <RadioButtonGroup select=".onRadioSelect" id="idSelectionRadioGroup" selectedIndex="0">
                        <RadioButton id="idOption1Radio" text="{i18n>option1Text}" tooltip="{i18n>option1Tooltip}" selected="true"/>
                        <RadioButton id="idOption2Radio" text="{i18n>option2Text}" tooltip="{i18n>option2Tooltip}"/>
                    </RadioButtonGroup>
                </VBox>
                <macros:FilterBar id="FilterBar" filterChanged=".handleFiltersChanged" search=".onAdvancedSearch" showAdaptFiltersButton="false" metaPath="/Stocks_SH/@com.sap.vocabularies.UI.v1.SelectionFields#filterBarMacro" visible="true" liveMode="false"/>
            </f:DynamicPageHeader>
        </f:header>
        <!-- 核心修改：用VBox包裹表格和长文本框，确保垂直排列+对齐 -->
        <f:content>
            <VBox id="_IDGenVBox1" width="100%" alignItems="Stretch" class="sapUiSmallMarginTop">
                <!-- 原有表格（保持不变，仅更新文本绑定） selectionMode="Multi"-->
                <mdc:Table
                    id="table"
                    header="{i18n>Table.Header.AddRequest}"
                    threshold="25"
                    showRowCount="true"
                    useColumnLabelsAsTooltips="true"
                    enableExport="true"
                  
                    enablePaste="false"
                    showPasteButton="false"
                    paste="onPaste"
                    type="ResponsiveTable"
                    delegate="{
                        name: 'zwm311countreq/delegate/JSONTableDelegate',
                        payload: {
                            bindingPath: 'Stocks>/Stocks'
                        }
                    }"
                    selectionChange=".onSelectionChange"
                >
                    <mdc:actions>
                        <Button
                            id="CreateRequestdButton"
                            text="{i18n>Button.CreateRequest}"
                            enabled="false"
                            press=".onBatchProcess"
                        />
                        <Button
                            id="CreateRequestdButton1"
                            text="{i18n>Button.ShowMessage}"
                            visible="false"
                            enabled="true"
                            press=".onShowmessage"
                        />
                    </mdc:actions>
                    <!-- 复选框选择列 -->
                    <mdct:Column id="_IDGenColumn00" width="65px" header="{i18n>Table.Column.Header.SEL}" >
                        <mdct:template>
                            <CheckBox id="_IDGenCheckBox1" selected="{Stocks>selected}" select=".onCheckBoxSelect" editable = "false"/>
                        </mdct:template>
                    </mdct:Column>
                    <!-- 1. message字段 -->
                    <mdct:Column id="_IDGenColumn0" propertyKey="message" width="400px" header="{i18n>Table.Column.Header.Message}">
                        <ObjectStatus id="_IDGenObjectStatus" class="sapUiSmallMarginBottom"
                            text="{Stocks>message}"
                            icon="{= 
                                ${Stocks>MSGTYPE} === '' || ${Stocks>MSGTYPE} === null ? '' : 
                                ${Stocks>MSGTYPE} === 'S' ? 'sap-icon://message-success' : 
                                'sap-icon://message-error'
                            }"
                            state="{= 
                                ${Stocks>MSGTYPE} === '' || ${Stocks>MSGTYPE} === null ? 'None' : 
                                ${Stocks>MSGTYPE} === 'S' ? 'Success' : 
                                'Error'
                            }" />
                    </mdct:Column>
                    <!-- 2. Category字段 -->
                    <mdct:Column id="_IDGenColumn1" propertyKey="Category" header="{i18n>Table.Column.Header.Category}">
                        <Text id="_IDGenText1" text="{Stocks>Category}"/>
                    </mdct:Column>
                    <!-- 3. zSchedule字段 -->
                    <mdct:Column id="_IDGenColumn2" propertyKey="zSchedule" header="{i18n>Table.Column.Header.Schedule}">
                        <Text id="_IDGenText2" text="{Stocks>zSchedule}"/>
                    </mdct:Column>
                    <!-- 4. matnr字段 -->
                    <mdct:Column id="_IDGenColumn3" propertyKey="matnr" header="{i18n>Table.Column.Header.MaterialNumber}">
                        <Text id="_IDGenText3" text="{Stocks>matnr}"/>
                    </mdct:Column>
                    <!-- 5. MAKTX字段 -->
                    <mdct:Column id="_IDGenColumn4" propertyKey="MAKTX" header="{i18n>Table.Column.Header.MaterialDescription}">
                        <Text id="_IDGenText4" text="{Stocks>MAKTX}"/>
                    </mdct:Column>
                    <!-- 6. LOCATIONTYPE字段 -->
                    <mdct:Column id="_IDGenColumn5" propertyKey="LOCATIONTYPE" header="{i18n>Table.Column.Header.LocationType}">
                        <Text id="_IDGenText5" text="{Stocks>LOCATIONTYPE}"/>
                    </mdct:Column>
                   <!-- 16. LGNUM -->
                    <mdct:Column id="_IDGenColumn15" propertyKey="LGNUM" header="{i18n>Table.Column.Header.LGNUM}">
                        <Text id="_IDGenText15" text="{Stocks>LGNUM}"/>
                    </mdct:Column>
                    <!-- 17. LGTYP -->
                    <mdct:Column id="_IDGenColumn16" propertyKey="LGTYP" header="{i18n>Table.Column.Header.LGTYP}">
                        <Text id="_IDGenText16" text="{Stocks>LGTYP}"/>
                    </mdct:Column>
                    <!-- 7. LOCATION字段 -->
                    <mdct:Column id="_IDGenColumn6" propertyKey="LOCATION" header="{i18n>Table.Column.Header.Location}">
                        <Text id="_IDGenText6" text="{Stocks>LOCATION}"/>
                    </mdct:Column>
                    <!-- 8. QUANTITY字段 -->
                    <mdct:Column id="_IDGenColumn7" propertyKey="QUANTITY" header="{i18n>Table.Column.Header.Quantity}">
                        <Text id="_IDGenText7" text="{Stocks>QUANTITY}"/>
                    </mdct:Column>
                    <!-- 8. Counter字段（可输入） -->
                    <mdct:Column id="_IDGenColumn8" propertyKey="Counter" header="{i18n>Table.Column.Header.Counter}">
                        <Input id="_IDGenInput8" value="{Stocks>Counter}" placeholder="{i18n>Input.Comment.Summary.Placeholder}"/>
                    </mdct:Column>
                    <!-- 9. Deadline字段（可输入，日期时间格式+选择帮助） -->
                    <mdct:Column id="_IDGenColumn9" propertyKey="Deadline" width="220px" header="{i18n>Table.Column.Header.Deadline}">
                        <DateTimePicker id="_IDGenDateTimePicker9"
                            value="{
                                path: 'Stocks>Deadline',
                                type: 'sap.ui.model.odata.type.DateTimeOffset'
                            }"
                            placeholder="{i18n>DateTimePicker.Deadline.Placeholder}"
                        />
                    </mdct:Column>
                    <!-- 11. ZCOGI字段 -->
                    <mdct:Column id="_IDGenColumn10" propertyKey="ZCOGI" header="{i18n>Table.Column.Header.COGIIndicator}">
                        <Text id="_IDGenText10" text="{Stocks>ZCOGI}"/>
                    </mdct:Column>
                    <!-- 12. lifnr字段 -->
                    <mdct:Column id="_IDGenColumn11" propertyKey="lifnr" header="{i18n>Table.Column.Header.VendorNumber}">
                        <Text id="_IDGenText11" text="{Stocks>lifnr}"/>
                    </mdct:Column>
                    <!-- 13. KUNNR字段 -->
                    <mdct:Column id="_IDGenColumn12" propertyKey="KUNNR" header="{i18n>Table.Column.Header.CustomerNumber}">
                        <Text id="_IDGenText12" text="{Stocks>KUNNR}"/>
                    </mdct:Column>
                    <!-- 14. DISPO字段 -->
                    <mdct:Column id="_IDGenColumn13" propertyKey="DISPO" header="{i18n>Table.Column.Header.MRPController}">
                        <Text id="_IDGenText13" text="{Stocks>DISPO}"/>
                    </mdct:Column>
                    <!-- 15. Project字段 -->
                    <mdct:Column id="_IDGenColumn14" propertyKey="Project" header="{i18n>Table.Column.Header.Project}">
                        <Text id="_IDGenText14" text="{Stocks>Project}"/>
                    </mdct:Column>

                    
                    <!-- 16. zComment字段（可输入长文本）
                    <mdct:Column id="colZComment" propertyKey="zComment" header="{i18n>Table.Column.Header.Comment}" width="200px">
                        <HBox id="_IDGenHBox" alignItems="Center" width="100%">
                            <Input id="_IDGenText" value="{Stocks>zComment}" class="comment-summary" placeholder="{i18n>Input.Comment.Summary.Placeholder}"/>
                            <Button id="_IDGenButton1" icon="sap-icon://edit" press=".onOpenCommentPopup" width="20%" tooltip="{i18n>Button.EditComment.Tooltip}"/>
                        </HBox>
                    </mdct:Column> -->
                </mdc:Table>

                <!-- 新增：表格下方的长文本框（TextArea） -->
                <VBox id="_IDGenVBox2" width="100%" class="sapUiSmallMarginTop" alignItems="Start">
                    <Label id="idLongTextLabel" text="{i18n>Label.Comment}" class="sapUiSmallMarginBottom"/>
                    <TextArea
                        id="idLongTextInput"
                        value="{Stocks>/zComment}"  
                        rows="6"  
                        width="800px" 
                        placeholder="{i18n>TextArea.Comment.Placeholder}"  
                        growing="true"  
                        growingMaxLines="99"  
                        class="sapUiSmallMarginBottom"
                    />
                </VBox>
            </VBox>
        </f:content>
   
        <f:footer>
            <OverflowToolbar id="_IDGenOverflowToolbar1">
                <Button id="messageButtonId" 
                    icon="{ path: 'message>/', formatter: '.buttonIconFormatter' }"
                    text="{= ${message>/}.length > 0 ? ${i18n>Button.Message.BaseText} + ' (' + ${message>/}.length + ')' : '' }" 
                    visible="{= ${message>/}.length > 0 }" 
                    type="{ path: 'message>/', formatter: '.buttonTypeFormatter' }"
                    press=".onMessagePopoverPress"/>
                <ToolbarSpacer id="_IDGenToolbarSpacer"/>
            </OverflowToolbar>
        </f:footer>
    </f:DynamicPage>
</mvc:View>